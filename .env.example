# Variables de Entorno - El Chancho Ganador

# ════════════════════════════════════════════════════════════════════════════════
# DISCORD
# ════════════════════════════════════════════════════════════════════════════════

# Token del bot Discord
# Obtener en: https://discord.com/developers/applications
DISCORD_TOKEN=TU_TOKEN_BOT_AQUI

# Canal donde se publican mensajes y resultados
# Obtener: Clic derecho en canal → Copiar ID
DISCORD_CHANNEL_ID=123456789012345678

# ID de usuario con permisos administrativos
# Obtener: Clic derecho en usuario → Copiar usuario ID
ADMIN_USER_ID=123456789012345678

# ════════════════════════════════════════════════════════════════════════════════
# BASE DE DATOS
# ════════════════════════════════════════════════════════════════════════════════

# Ruta de SQLite (opcional, default: ./data/bot.sqlite3)
# SQLITE_PATH=./data/bot.sqlite3

# ════════════════════════════════════════════════════════════════════════════════
# AUDITORÍA Y VERIFICACIÓN PÚBLICA
# ════════════════════════════════════════════════════════════════════════════════

# Ruta local del repositorio de auditoría pública
# (opcional, default: /home/linx/Escritorio/VPS/sorteos-auditoria-publica)
# PUBLIC_AUDIT_REPO_PATH=/ruta/a/sorteos-auditoria-publica

# ════════════════════════════════════════════════════════════════════════════════
# VIRUSTOTAL - Análisis de Integridad (OPCIONAL)
# ════════════════════════════════════════════════════════════════════════════════

# API Key de VirusTotal (opcional)
# - Sin configurar: Usa análisis de hashes gratuito (recomendado para empezar)
# - Configurado: Acceso a análisis detallados y escaneo de URLs prioritario
# Obtener en: https://www.virustotal.com/gui/home/upload
# VIRUSTOTAL_API_KEY=tu_api_key_aqui

# ════════════════════════════════════════════════════════════════════════════════
# ENTORNO (dev/production)
# ════════════════════════════════════════════════════════════════════════════════

# NODE_ENV=production
